{
    "description": "Toggle Full Screen (fn+f & ctrl+cmd+f to ctrl+alt+esc)",
    "manipulators": [
        {
            "from": {
                "key_code": "f",
                "modifiers": {
                    "mandatory": ["control", "command"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "escape",
                    "modifiers": ["control", "option"]
                }
            ],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "escape",
                "modifiers": {
                    "mandatory": ["control", "option"],
                    "optional": ["any"]
                }
            },
            "to": [
                {
                    "key_code": "f",
                    "modifiers": ["fn"]
                }
            ],
            "type": "basic"
        }
    ]
}
